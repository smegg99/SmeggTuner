<?xml version="1.0" encoding="utf-8"?>
<MsixPackagingToolTemplate
    xmlns="http://schemas.microsoft.com/msix/packaging/msixpackagingtool/template/2022">
    <Settings
        AllowTelemetry="false"
        ApplyACLsToPackageFiles="true"
        GenerateCommandLineFile="true"
        AllowPromptForPassword="false">
    </Settings>
    <Installer
        Path="smeggtuner"
        Arguments=""
        InstallLocation="C:\Program Files\Smegg99\SmeggTuner">
    </Installer>
    <PackageInformation
        PackageName="SmeggTuner"
        PackageDisplayName="SmeggTuner"
        PublisherName="CN=Smegg99"
        PublisherDisplayName="Smegg99"
        Version="1.1.0.0"
        PackageDescription="Free and open-source accordion tuner.">
        <Capabilities>
            <Capability Name="runFullTrust" />
            
        </Capabilities>
        <Applications>
            <Application
                Id="SmeggTuner"
                Description="Free and open-source accordion tuner."
                DisplayName="SmeggTuner"
                ExecutableName="smeggtuner"
                EntryPoint="Windows.FullTrustApplication">
                
            </Application>
        </Applications>
        <Resources>
            <Resource Language="en-us" />
        </Resources>
        <Dependencies>
            <TargetDeviceFamily Name="Windows.Desktop" MinVersion="10.0.17763.0" MaxVersionTested="10.0.19041.0" />
        </Dependencies>
        <Properties>
            <Framework>false</Framework>
            <DisplayName>SmeggTuner</DisplayName>
            <PublisherDisplayName>Smegg99</PublisherDisplayName>
            <Description>Free and open-source accordion tuner.</Description>
            <Logo>Assets\AppIcon.png</Logo>
        </Properties>
    </PackageInformation>
    <SaveLocation PackagePath="SmeggTuner.msix" />
    <PackageIntegrity>
        <CertificatePath></CertificatePath>
    </PackageIntegrity>
</MsixPackagingToolTemplate>
